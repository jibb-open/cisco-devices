function reactToEmailEdit() {
  xapi.Event.UserInterface.Extensions.Widget.Action.on((event) => {
    if (event.Type === "released" && event.WidgetId === "jibb_email") {
      xapi.Command.UserInterface.Message.TextInput.Display({
        FeedbackId: "user_email",
        Title: "Set email",
        Text: "Optional. Enter an email for PDF in standalone and Webex sessions. If left blank, JIBB may use a meeting email when available.",
        Placeholder: RecordingEmail || "Enter email",
      });

    }
  });
}

function setEmailistener() {
  xapi.Event.UserInterface.Message.TextInput.Response.on(async (event) => {
    if (event.FeedbackId === "user_email") {
      RecordingEmail = event.Text.trim();
    }
  });
}
